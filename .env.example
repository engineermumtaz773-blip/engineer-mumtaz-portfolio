# Public site URL used for absolute links
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Resend API key used to authenticate email sends
# Required: set this in Vercel as RESEND_API_KEY
RESEND_API_KEY=

# Sender and recipient addresses for contact form emails.
# Supported names (either set these or the RESEND_* equivalents):
# - CONTACT_FROM_EMAIL (repo default)
# - CONTACT_TO_EMAIL   (repo default)
# Backward-compatible / alternative names (common on Vercel):
# - RESEND_FROM
# - RESEND_TO
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
CONTACT_TO_EMAIL=

# Optional analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=
