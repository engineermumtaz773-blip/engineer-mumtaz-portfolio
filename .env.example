# Public site URL used for absolute links
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Resend API key used to authenticate email sends
# Required: set this in Vercel as RESEND_API_KEY
RESEND_API_KEY=

# Sender and recipient addresses for contact form emails (Resend names)
# Use the standard Resend environment variable names in Vercel:
# - RESEND_FROM (sender)
# - RESEND_TO   (recipient)
RESEND_FROM=Portfolio <onboarding@resend.dev>
RESEND_TO=

# Optional analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=
